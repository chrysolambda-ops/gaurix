#!/usr/bin/env bash
set -euo pipefail

MSG_FILE="$1"
MSG="$(sed -n '1p' "$MSG_FILE")"

if [[ ${#MSG} -lt 10 ]]; then
  echo "Commit message too short. Use a descriptive message (>=10 chars)." >&2
  exit 1
fi

# Allow merges/reverts/chore commits, and conventional package commits.
if [[ "$MSG" =~ ^(Merge|Revert|chore:|docs:|ci:|Add|Update|Mark|Use) ]]; then
  exit 0
fi

echo "Commit message should start with one of: Add/Update/Mark/Use/docs:/ci:/chore:" >&2
exit 1
